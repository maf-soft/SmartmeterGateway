      "targets": [
        {
          "dataset": "iox",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH d AS (\r\n  SELECT\r\n    time,\r\n    CASE WHEN meter='${meter_netz}' THEN 'Netz'\r\n         WHEN meter='${meter_haus}' THEN 'Haus'\r\n         ELSE meter END AS meter,\r\n    direction,\r\n    (value - LAG(value) OVER (PARTITION BY meter, direction ORDER BY time)) * 4 AS delta\r\n  FROM home_readings\r\n  WHERE \"database\"='origin'\r\n    AND direction IN ('EINSP','BEZUG')\r\n    AND $__timeFilter(time)\r\n),\r\nsigned AS (\r\n  SELECT\r\n    time,\r\n    meter,\r\n    SUM(CASE WHEN direction='BEZUG' THEN delta ELSE -delta END) AS value\r\n  FROM d\r\n  GROUP BY time, meter\r\n)\r\nSELECT\r\n  time,\r\n  MAX(CASE WHEN meter='Netz' THEN value END) AS \"Netz\",\r\n  MAX(CASE WHEN meter='Haus' THEN value END) AS \"Haus\",\r\n  MAX(CASE WHEN meter='Haus' THEN value END) - MAX(CASE WHEN meter='Netz' THEN value END) AS \"Produktion\"\r\nFROM signed\r\nGROUP BY time\r\nORDER BY time;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ]
          }
        }
